   	 void pattern5() {
       
        int num = 1;
        for (int i = 1; i <= 3; i++) {
            int spaces = (i == 2) ? 0 : 1;
            for (int s = 1; s <= spaces; s++) System.out.print(" ");
            
            if (i == 2) {
